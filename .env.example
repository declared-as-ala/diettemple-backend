# ── MinIO Object Storage ──────────────────────────────────────────────────────
# In Docker: MINIO_ENDPOINT=minio (service name), MINIO_PORT=9000
# Local dev outside Docker: MINIO_ENDPOINT=localhost, MINIO_PORT=9000
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=diettemple
MINIO_SECRET_KEY=change-this-to-a-strong-secret

# ── Groq (optional): primary gym + meal vision when set
GROQ_API_KEY=
# Optional model overrides (defaults: meta-llama/llama-4-scout-17b-16e-instruct)
# GROQ_GYM_MODEL=
# GROQ_MEAL_MODEL=
# GROQ_TIMEOUT_MS=10000
